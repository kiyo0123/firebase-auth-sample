# このファイルを `.env` にコピーして、Firebase Console の値を入れてください。
#   cp .env.example .env
#
# 値の場所: Firebase Console > プロジェクトの設定 > マイアプリ (Web) >
#           「SDK setup and configuration > Config」
#
# Vite はビルド時に VITE_ プレフィックスの変数だけをクライアントへ展開します。
# Firebase の Web API キーは公開前提の識別子（秘密情報ではない）ですが、
# このサンプルでは config をリポジトリに含めない方針のため .env で管理します。
# .env は .gitignore で除外されています。

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
