# Firebase Console > プロジェクトの設定 > マイアプリ (Web) からコピーして
# このファイルを `.env` にコピーして値を埋めてください。
#
# Vite はビルド時に VITE_ プレフィックスの変数だけをクライアントに公開します。
# Firebase の Web API キーは公開前提の識別子なので、これらを Git に含めても
# 致命的な秘密漏洩にはなりません（アクセス制御は Auth/セキュリティルールで行う）。
# ただし習慣として .env はコミットしない運用にしています。

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
